# ===========================================
# BizzAuto CRM - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=production
PORT=4000

# Database (PostgreSQL)
DATABASE_URL=postgresql://bizzauto:your_secure_password@localhost:5432/bizzauto_db
POSTGRES_USER=bizzauto
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=bizzauto_db

# Redis (for caching/sessions)
REDIS_URL=redis://localhost:6379

# JWT Authentication (use 32+ character strings)
JWT_SECRET=your-very-long-jwt-secret-key-minimum-32-chars
JWT_REFRESH_SECRET=your-very-long-jwt-refresh-secret-key-minimum-32-chars

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# API URL
API_URL=http://localhost:4000/api

# ===========================================
# Third-Party Services (Optional)
# ===========================================

# OpenRouter (AI features)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Cloudflare (CDN/DDoS protection)
CLOUDFLARE_API_KEY=your-cloudflare-api-key
CLOUDFLARE_EMAIL=your@email.com
CLOUDFLARE_ZONE_ID=your-zone-id

# WhatsApp (Evolution API)
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=bizzauto

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="BizzAuto CRM <noreply@bizzautoai.com>"

# Razorpay (Payments)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# Application Settings
# ===========================================

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info

# Session
SESSION_SECRET=your-session-secret-minimum-32-characters